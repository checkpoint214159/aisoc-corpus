---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ReaderLayout from "../../layouts/ReaderLayout.astro";
import HoverPreview from "../../components/HoverPreview.tsx";
import backlinksData from "../../lib/backlinks.json";

interface Props {
  topic: CollectionEntry<"topics">;
}

export async function getStaticPaths() {
  const topics = await getCollection("topics");
  return topics.map((topic: CollectionEntry<"topics">) => ({
    params: { slug: topic.id.replace(/\.md$/, "") },
    props: { topic },
  }));
}

const { topic } = Astro.props as Props;
const { Content, headings } = await render(topic);
const slug = topic.id.replace(/\.md$/, "");
const backlinks =
  (backlinksData as Record<string, { slug: string; title: string }[]>)[slug] ||
  [];
---

<ReaderLayout
  title={topic.data.title}
  headings={headings}
  backlinks={backlinks}
>
  <header>
    <h1>{topic.data.title}</h1>
    <div class="topic-meta">
      <span class="meta-badge">{topic.data.difficulty}</span>
      <span class="meta-badge">{topic.data.category.replace(/-/g, " ")}</span>
      {topic.data.domains.map((d: string) => <span class="meta-tag">{d}</span>)}
    </div>
    <div class="topic-tags" aria-label="Topic tags">
      {
        topic.data.tags.map((tag: string) => (
          <span class="meta-tag">{tag}</span>
        ))
      }
    </div>
    <p class="topic-author">
      Author <a href={`https://github.com/${topic.data.author}`}
        >@{topic.data.author}</a
      >
    </p>
  </header>
  <Content />
  {
    topic.data.citations && topic.data.citations.length > 0 && (
      <section class="citations">
        <h2>Citations</h2>
        <ol>
          {topic.data.citations.map((c: { title: string; url: string }) => (
            <li>
              <a href={c.url} target="_blank" rel="noopener noreferrer">
                {c.title}
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }
  <HoverPreview client:load />
</ReaderLayout>

<style>
  .topic-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.7rem;
  }

  .topic-author {
    margin: 0 0 2rem;
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  .topic-author a {
    color: var(--color-muted-strong);
    transition: color 0.2s ease;
  }

  .topic-author a:hover {
    color: var(--color-accent);
  }

  .meta-badge {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: rgba(204, 255, 0, 0.1);
    color: var(--color-accent);
  }

  .meta-tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: var(--color-surface);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  .citations {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .citations h2 {
    font-size: 1.1rem;
  }

  .citations ol {
    padding-left: 1.2rem;
  }

  .citations a {
    color: var(--color-accent-secondary);
    font-size: 0.85rem;
  }

  .citations a:hover {
    color: var(--color-accent);
  }
</style>
